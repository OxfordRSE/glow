# GLOW Development Environment Configuration
# Copy this file to .env and customize for local development
# DO NOT commit .env or .env.* files (except .env.example)

# ============================================================================
# Glow API Configuration
# ============================================================================

# Secret key for JWT token signing (change in production!)
GLOW_SECRET_KEY=dev-secret-key-change-in-production

# CORS origins (comma-separated list for production, JSON array for compose)
# GLOW_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Minimum N for privacy protection (suppress aggregates with cells < MIN_N)
# GLOW_MIN_N=5

# Data cache refresh interval in hours
# GLOW_DATA_REFRESH_HOURS=1

# Path to cached data (Parquet format)
# GLOW_DATA_CACHE_PATH=.cache.parquet

# ============================================================================
# ODK Central Integration (set by dev-init.sh)
# ============================================================================

# ODK Central API URL (internal Docker network)
# GLOW_ODK_API_URL=http://odk-service:8383

# ODK Central API credentials (auto-generated by dev-init.sh)
# GLOW_ODK_API_EMAIL=api@glow.local
# GLOW_ODK_API_PASSWORD=<generated>

# ODK Central project and form IDs
# GLOW_ODK_PROJECT_ID=1
# GLOW_ODK_FORM_ID=bewell_questionnaire

# ============================================================================
# Database Configuration
# ============================================================================

# PostgreSQL credentials for Glow metadata database
POSTGRES_DB=glow
POSTGRES_USER=glow
POSTGRES_PASSWORD=change-me-in-production

# Metadata database URL (auto-constructed from above in compose.yml)
# GLOW_METADATA_DATABASE_URL=postgresql+psycopg://glow:change-me-in-production@api-db:5432/glow

# ============================================================================
# ODK Central Configuration
# ============================================================================

# ODK Central domain
# ODK_DOMAIN=odk.local

# ODK Central ports
# ODK_HTTP_PORT=8080
# ODK_HTTPS_PORT=8443

# ODK Central database credentials
# ODK_POSTGRES_DB=odk
# ODK_POSTGRES_USER=odk
# ODK_POSTGRES_PASSWORD=odk

# ODK Central admin email (set by dev-init.sh, stored in .env.dev)
# ODK_SYSADMIN_EMAIL=admin@example.com

# ODK Central email configuration
# ODK_EMAIL_FROM=no-reply@odk.local
# ODK_EMAIL_PORT=1025
# ODK_EMAIL_SECURE=false
# ODK_EMAIL_IGNORE_TLS=true

# SSL configuration (selfsign for dev, letsencrypt for production)
# ODK_SSL_TYPE=selfsign

# ============================================================================
# Dashboard Configuration
# ============================================================================

# Node environment (development or production)
# NODE_ENV=production

# Public API base URL (for frontend to reach backend)
# PUBLIC_API_BASE=http://127.0.0.1:8000

# ============================================================================
# Development Tools (auto-set by dev-init.sh)
# ============================================================================

# Credentials saved in .env.dev (gitignored):
# - ODK_ADMIN_EMAIL / ODK_ADMIN_PASSWORD
# - ODK_API_EMAIL / ODK_API_PASSWORD  
# - GLOW_ADMIN_USER / GLOW_ADMIN_PASSWORD

# Run `./dev-init.sh` to auto-configure ODK and Glow with test data
