# Environment configuration for ib-ox-core
# Copy to .env and customize as needed

# ─── API Configuration ────────────────────────────────────────────────────────

# JWT signing secret — MUST be set to a strong random value in production
IB_OX_SECRET_KEY=change-me-in-production

# Minimum distinct student count required to avoid suppression
IB_OX_MIN_N=5

# Path to data file (CSV or Parquet) inside the API container
# IB_OX_DATA_PATH=/data/data.csv

# How often to reload data from disk (hours)
# IB_OX_DATA_REFRESH_HOURS=24

# JWT algorithm
# IB_OX_ALGORITHM=HS256

# JWT token lifetime (minutes)
# IB_OX_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database URL for auth/user storage
# IB_OX_DATABASE_URL=sqlite:////data/auth.db

# CORS allowed origins (JSON array)
# IB_OX_CORS_ORIGINS=["http://localhost:5173"]

# ─── AWS Deployment (deploy.sh) ───────────────────────────────────────────────

# AWS region for deployment
# AWS_REGION=eu-west-2
