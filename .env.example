# Environment configuration for glow-core
# Copy to .env and customize as needed

# ─── API Configuration ────────────────────────────────────────────────────────

# JWT signing secret — MUST be set to a strong random value in production
GLOW_SECRET_KEY=change-me-in-production

# Minimum distinct student count required to avoid suppression
GLOW_MIN_N=5

# ODK Central connection settings
# GLOW_ODK_API_URL=http://odk-service:8383
# GLOW_ODK_API_EMAIL=admin@example.com
# GLOW_ODK_API_PASSWORD=change-me-in-production
# GLOW_ODK_PROJECT_ID=1
# GLOW_ODK_FORM_ID=bewell_questionnaire

# Optional data cache path for DataFrame persistence
# GLOW_DATA_CACHE_PATH=/data/cache.parquet

# How often to poll ODK Central for new data (hours)
# GLOW_DATA_REFRESH_HOURS=1

# JWT algorithm
# GLOW_ALGORITHM=HS256

# JWT token lifetime (minutes)
# GLOW_ACCESS_TOKEN_EXPIRE_MINUTES=480

# Database URL for auth/user storage
# GLOW_METADATA_DATABASE_URL=postgresql+psycopg://glow:change-me-in-production@api-db:5432/glow

# CORS allowed origins (JSON array)
# GLOW_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Dashboard API base URL exposed to the browser
# PUBLIC_API_BASE=http://127.0.0.1:8000

# Postgres container defaults for compose
# POSTGRES_DB=glow
# POSTGRES_USER=glow
# POSTGRES_PASSWORD=change-me-in-production

# ─── Optional ODK Central Profile ────────────────────────────────────────────

# Enable with: docker compose --profile odk up

# Pin the official ODK Central image tag used for service/nginx
# ODK_CENTRAL_TAG=v2026.1.2

# Public domain used by ODK Central. ODK expects a real host name.
# ODK_DOMAIN=odk.example.com

# Admin and support email for ODK Central
# ODK_SYSADMIN_EMAIL=admin@example.com

# TLS mode for the ODK nginx container (e.g. selfsign, letsencrypt, customssl)
# ODK_SSL_TYPE=selfsign

# Host ports exposed by ODK Central's nginx container
# ODK_HTTP_PORT=8080
# ODK_HTTPS_PORT=8443

# ODK Central database credentials
# ODK_POSTGRES_DB=odk
# ODK_POSTGRES_USER=odk
# ODK_POSTGRES_PASSWORD=change-me-too

# Optional outbound mail overrides for ODK Central
# ODK_EMAIL_FROM=no-reply@odk.example.com
# ODK_EMAIL_HOST=mail
# ODK_EMAIL_PORT=1025
# ODK_EMAIL_SECURE=false
# ODK_EMAIL_IGNORE_TLS=true

# Optional OIDC toggle for ODK Central
# ODK_OIDC_ENABLED=false

# ─── AWS Deployment (deploy.sh) ───────────────────────────────────────────────

# AWS region for deployment
# AWS_REGION=eu-west-2
