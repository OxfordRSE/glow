# Runtime-generated secrets for Glow deployment
# This file is created by activate-stack.sh and loaded by containers via env_file
# DO NOT edit manually - values are auto-generated during deployment

# ODK API User Credentials (glow-api@<domain>)
ODK_API_EMAIL=
ODK_API_PASSWORD=

# Application secrets
GLOW_SECRET_KEY=
POSTGRES_PASSWORD=

# ODK Central secrets (managed by ODK)
# These are generated by activate-stack.sh and used by ODK Central containers
