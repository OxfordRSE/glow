# Example Terraform Configuration
# Copy to terraform.tfvars and customize for your deployment

# ─── AWS Configuration ────────────────────────────────────────────────────────

aws_region = "eu-west-2"
app_name   = "glow-core"

# Availability zone (must be in the same region)
availability_zone = "eu-west-2a"

# ─── Domain Configuration ─────────────────────────────────────────────────────

# Root domain name (Route 53 hosted zone must exist for parent domain)
# This configures:
#   - glow.example.ac.uk     → Dashboard
#   - api.glow.example.ac.uk → API
#   - odk.glow.example.ac.uk → ODK Central
domain_name = "glow.example.ac.uk"

# ─── EC2 Configuration ────────────────────────────────────────────────────────

# Instance type (t3.medium recommended for production)
instance_type = "t3.medium"

# Persistent data volume size in GB
data_volume_size_gb = 100

# ─── SSH Access ───────────────────────────────────────────────────────────────

# SSH key pair name (must already exist in AWS EC2)
ssh_key_name = "my-key-pair"

# CIDR blocks allowed to SSH (restrict to your IP in production)
# Example: ["1.2.3.4/32"] for single IP
ssh_allowed_cidr_blocks = ["0.0.0.0/0"]
