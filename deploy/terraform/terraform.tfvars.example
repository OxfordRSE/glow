# Example Terraform Configuration
# Copy to terraform.tfvars and customize for your deployment

# ─── AWS Configuration ────────────────────────────────────────────────────────

aws_region = "eu-west-2"
app_name   = "glow-core"

# Availability zone (must be in the same region)
availability_zone = "eu-west-2a"

# Optional: Override auto-generated Terraform state bucket name
# If not set, bucket name is auto-generated from domain_name
# Example: "glow.example.ac.uk" -> "glow-example-ac-uk-tfstate"
# tfstate_bucket_name = "my-custom-glow-tfstate-bucket"

# ─── Domain Configuration ─────────────────────────────────────────────────────

# Root domain name
# This configures:
#   - <domain>     → Dashboard
#   - api.<domain> → API
#   - odk.<domain> → ODK Central

# Example 1: You own the Route 53 hosted zone
domain_name = "glow.example.ac.uk"
manage_dns  = true  # Auto-create DNS records in Route 53 (default)

# Example 2: Delegated subdomain (parent organization owns glow-project.org)
# domain_name = "eg.glow-project.org"
# manage_dns  = false  # Don't create Route 53 records; deployment will output DNS instructions

# ─── EC2 Configuration ────────────────────────────────────────────────────────

# Instance type (t3.medium recommended for production)
instance_type = "t3.medium"

# Persistent data volume size in GB
data_volume_size_gb = 100

# ─── Deployment Configuration ─────────────────────────────────────────────────

# Git repository (defaults to official GLOW repo)
# git_repo_url = "https://github.com/OxfordRSE/glow.git"

# Git reference to deploy (leave empty for latest release)
# git_ref = "v1.2.3"  # Specific version
# git_ref = "main"    # Latest main branch (testing only)
git_ref = "" # Latest release (recommended)